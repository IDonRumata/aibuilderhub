---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = 'The honest guide to building with AI. Real tests, real results, no fluff. Compare AI app builders, vibe coding tools, and no-code platforms.',
  canonical,
  type = 'website',
} = Astro.props;

const siteUrl = 'https://aibuilderhub.app';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = title === 'Home'
  ? 'AIBuilderHub - The Honest Guide to Building with AI'
  : `${title} | AIBuilderHub`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- impact.com site verification -->
    <meta name='impact-site-verification' value='b00ba283-8830-44d0-8cfd-3096b4d376d3' />

    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TX5NV1XJX5"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TX5NV1XJX5');
    </script>

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="AIBuilderHub" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!--
      Theme init script — runs BEFORE paint to prevent flash of wrong theme.
      Reads saved preference from localStorage; defaults to dark if none set.
    -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('aibh-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved ?? (prefersDark ? 'dark' : 'light');
        if (theme === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>

  <body class="font-sans min-h-screen flex flex-col antialiased" style="background-color: var(--color-bg); color: var(--color-text);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme toggle logic (runs after DOM is ready) -->
    <script is:inline>
      window.__toggleTheme = function () {
        const html = document.documentElement;
        const isLight = html.classList.toggle('light');
        localStorage.setItem('aibh-theme', isLight ? 'light' : 'dark');

        // Update toggle button icon
        const icon = document.getElementById('theme-icon');
        if (icon) icon.textContent = isLight ? '☀️' : '🌙';
      };
    </script>
  </body>
</html>
