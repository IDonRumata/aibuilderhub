---
const navLinks = [
  { href: '/blog', label: 'Reviews' },
  { href: '/tools', label: 'Tools' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 header-bg backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-1 shrink-0 font-bold text-xl" aria-label="AIBuilderHub home">
      <span style="color: var(--color-accent);">AI</span>
      <span style="color: var(--color-text);">BuilderHub</span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors"
          style={
            currentPath.startsWith(link.href)
              ? `color: var(--color-text); background-color: var(--color-surface-2);`
              : `color: var(--color-muted);`
          }
          onmouseover="this.style.color='var(--color-text)'; this.style.backgroundColor='var(--color-surface-2)'"
          onmouseout={
            currentPath.startsWith(link.href)
              ? "this.style.color='var(--color-text)'"
              : "this.style.color='var(--color-muted)'; this.style.backgroundColor='transparent'"
          }
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle light/dark theme"
        onclick="window.__toggleTheme()"
        title="Switch theme"
      >
        <span id="theme-icon">🌙</span>
      </button>

      <!-- Newsletter CTA -->
      <a href="/#newsletter" class="btn-primary shrink-0">
        Weekly digest
      </a>
    </div>
  </div>
</header>

<!-- Sync icon to current theme on page load -->
<script is:inline>
  (function () {
    const icon = document.getElementById('theme-icon');
    if (icon) {
      icon.textContent = document.documentElement.classList.contains('light') ? '☀️' : '🌙';
    }
  })();
</script>
